# ─────────────────────────────────────────────────────────────────────────────
# Cincinnati Civic Platform — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.
# ─────────────────────────────────────────────────────────────────────────────

# Socrata App Token (low sensitivity — exposed in browser bundle)
# Register free at: https://data.cincinnati-oh.gov/profile/edit/developer_settings
VITE_SOCRATA_APP_TOKEN=your_socrata_app_token_here

# Geocoding API Key (low sensitivity — exposed in browser bundle)
# Use Google Maps or Mapbox. Restrict the key to your domain in the provider dashboard.
# Google Maps: https://console.cloud.google.com → Maps JavaScript API + Geocoding API
# Mapbox: https://account.mapbox.com/access-tokens
VITE_GEOCODING_API_KEY=your_geocoding_api_key_here
VITE_GEOCODING_PROVIDER=google   # or "mapbox"

# OHGO Traffic API Key (low sensitivity — exposed in browser bundle)
# Register free at: https://ohgo.com → Developer → API Key
# Enables live traffic incidents, construction zones, and ODOT cameras in Address Lookup.
VITE_OHGO_API_KEY=your_ohgo_api_key_here

# ─── Sensitive Keys (Cloudflare Worker only — NEVER put these in VITE_ vars) ───
# These belong in your Cloudflare Worker's environment variable secrets,
# NOT in this file. They are listed here only for documentation purposes.

# ANTHROPIC_API_KEY=sk-ant-...         → Cloudflare Worker secret
# CENSUS_API_KEY=your_census_key_here  → Cloudflare Worker secret
#   Get a free Census key at: https://api.census.gov/data/key_signup.html
